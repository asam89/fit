# --- Web Dashboard ---
SECRET_KEY=                    # session signing key (generate: python -c "import secrets; print(secrets.token_hex(32))")
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
ALLOWED_ORIGINS=

# --- Encryption (for bot tokens at rest) ---
ENCRYPTION_KEY=                # Fernet key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

# --- External APIs ---
OPENAI_API_KEY=                # Whisper voice transcription (optional for text-only)
ANTHROPIC_API_KEY=             # Claude — meal parsing, diet plans, routing, analysis

# --- Device Webhook (Phase 2) ---
INGEST_WEBHOOK_TOKEN=

# --- Optional Food API fallback ---
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# --- Database ---
DATABASE_PATH=./fitnessbot.db

# --- AI Models ---
ANALYSIS_MODEL=claude-sonnet-4-6
ROUTER_MODEL=claude-sonnet-4-6

# --- Google OAuth (optional — enables "Sign in with Google") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://fit.140.238.131.77.nip.io/auth/google/callback

